# Database Configuration
# For development (SQLite):
DATABASE_URL=./leona.db
# Or with sqlite:// prefix:
# DATABASE_URL=sqlite://./leona.db

# For production (Supabase PostgreSQL):
# DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server Configuration
PORT=8080
BASE_URL=http://localhost:8080

# Payment Configuration (Mollie)
MOLLIE_API_KEY=test_xxxxxxxxxxxxx
# For production:
# MOLLIE_API_KEY=live_xxxxxxxxxxxxx

# Stripe Configuration (Legacy - use Mollie instead)
STRIPE_API_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# SMTP Configuration (Netim - leona-cravit.be)
SMTP_HOST=mail1.netim.hosting
SMTP_PORT=465
SMTP_USER=support@leona-cravit.be
SMTP_PASS=your-email-password
SMTP_FROM=support@leona-cravit.be

# Development Notes:
# - For Gmail SMTP, you need to enable 2FA and create an App Password
# - Mollie API keys: https://my.mollie.com/dashboard/developers/api-keys
# - Supabase keys: Project Settings > API > Project URL and service_role key
# - Run migrations/001_create_tables.sql in Supabase SQL Editor before first use
# - Webhook server runs on separate port (8081) - see cmd/webhook/main.go
# - For production, use environment variables instead of .env file
