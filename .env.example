# Database Configuration
# For development (SQLite):
DATABASE_URL=./leona.db
# Or with sqlite:// prefix:
# DATABASE_URL=sqlite://./leona.db

# For production (Supabase PostgreSQL):
# DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Server Configuration
PORT=8080
BASE_URL=http://localhost:8080

# Stripe Configuration
STRIPE_API_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# SMTP Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@leona.io

# Development Notes:
# - For Gmail SMTP, you need to enable 2FA and create an App Password
# - Stripe keys can be obtained from https://dashboard.stripe.com/apikeys
# - Webhook secret from https://dashboard.stripe.com/webhooks
# - For production, use environment variables instead of .env file
